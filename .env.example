MIKROTIK_HOST=
MIKROTIK_PORT=8729
MIKROTIK_USERNAME=
MIKROTIK_PASSWORD=
MIKROTIK_USE_SSL=true
MIKROTIK_SSL_VERIFY=false
LOG_LEVEL=INFO
PRINT_RESULT_TO_STDOUT=true
RUN_MODE=loop
COLLECTION_INTERVAL=60
PERSISTENCE_ENABLED=true
PERSISTENCE_PATH=/data/snapshots
PERSISTENCE_RETENTION_DAYS=7
TZ=Europe/Kyiv
