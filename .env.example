MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8729
MIKROTIK_USERNAME=admin
MIKROTIK_PASSWORD=change-me
MIKROTIK_USE_SSL=true
MIKROTIK_SSL_VERIFY=false

LOG_LEVEL=INFO
PRINT_RESULT_TO_STDOUT=false
RUN_MODE=loop
COLLECTION_INTERVAL=60

PERSISTENCE_ENABLED=true
PERSISTENCE_PATH=/data/snapshots
PERSISTENCE_RETENTION_DAYS=7
IDLE_TIMEOUT_SECONDS=900

API_ENABLED=true
API_HOST=0.0.0.0
API_PORT=8000
WEB_HOST=0.0.0.0
WEB_PORT=8080
BACKEND_API_URL=http://mikrotrack-app:8000

TZ=UTC
